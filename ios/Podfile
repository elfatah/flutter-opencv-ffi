# ios/Podfile — Flutter's canonical app Podfile, plus the local native_opencv
# development pod.
#
# native_opencv is the iOS analogue of android/app/src/main/cpp/CMakeLists.txt:
# it compiles the shared native/native_opencv.cpp into the app so dart:ffi's
# DynamicLibrary.process() can resolve opencv_process / opencv_free_buffer.
# CHECKPOINT 1: no OpenCV is linked (the podspec leaves HAVE_OPENCV undefined).

platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure \"flutter pub get\" is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  # Local FFI build glue — compiles the shared native/native_opencv.cpp into the
  # app and links OpenCV. The podspec sits at the repo root (one level up from
  # ios/) so its vendored xcframework path doesn't escape the pod root.
  pod 'native_opencv', :path => '..'

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # The OpenCV opencv2.xcframework simulator slice is arm64-only (built for an
      # M1/Apple-Silicon simulator, no x86_64). Flutter's generic simulator build
      # would otherwise also build x86_64, and ld drops the arm64-only OpenCV
      # ("fat file missing arch 'x86_64'") -> every cv:: symbol undefined. Exclude
      # x86_64 for the simulator so the whole build is arm64, matching the slice.
      config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'x86_64'
    end
  end
end
